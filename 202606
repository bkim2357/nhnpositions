const GRP_CLS = {Tech:"b-tech",Business:"b-biz",Corporate:"b-corp",Design:"b-des"};
const GRP_LABEL = {Tech:"Tech",Business:"Business",Corporate:"Corporate",Design:"Design"};
const EMP_CLS = {정사원:"b-seiin",계약사원:"b-keiyak",준사원:"b-jun"};

function reqHtml(req) {
  if (!req || req.length === 0) return '<span class="req-none">—</span>';
  return '<ul class="req-text">' + req.map(r => `<li>${r}</li>`).join('') + '</ul>';
}

function buildTable(rows) {
  if (rows.length === 0) return '';
  return `<div class="tbl-wrap"><table>
    <colgroup><col class="c-grp"><col class="c-pos"><col class="c-emp"><col class="c-req"></colgroup>
    <thead><tr><th>직군</th><th>포지션명 / 직종</th><th>고용형태</th><th>필수요건</th></tr></thead>
    <tbody>
      ${rows.map(d => {
        const gc = GRP_CLS[d.grp] || 'b-etc';
        const gl = GRP_LABEL[d.grp] || d.grp;
        const ec = EMP_CLS[d.emp] || 'b-seiin';
        const nmEl = d.url
          ? `<a href="${d.url}" target="_blank" rel="noopener">${d.nm}</a>`
          : d.nm;
        return `<tr data-corp="${d.corp}" data-grp="${d.grp}" data-emp="${d.emp}" data-nm="${d.nm}" data-req="${(d.req||[]).join(' ')}">
          <td><span class="badge ${gc}">${gl}</span></td>
          <td><div class="pos-name">${nmEl}</div><div class="pos-series">${d.sr}</div></td>
          <td><span class="badge ${ec}">${d.emp}</span></td>
          <td>${reqHtml(d.req)}</td>
        </tr>`;
      }).join('')}
    </tbody>
  </table></div>`;
}

const GRP_ORDER = {Tech:0, Business:1, Corporate:2, Design:3};

function sortData(data) {
  return [...data].sort((a, b) => {
    const go = (GRP_ORDER[a.grp] ?? 99) - (GRP_ORDER[b.grp] ?? 99);
    if (go !== 0) return go;
    return a.sr.localeCompare(b.sr, 'ja');
  });
}

function buildSections(data) {
  const main = document.getElementById('main');
  main.innerHTML = '';
  CORPS.forEach(corp => {
    const rows = sortData(data.filter(d => d.corp === corp.id));
    const sec = document.createElement('div');
    sec.className = 'corp-section';
    sec.dataset.corp = corp.id;
    sec.innerHTML = `
      <div class="corp-header">
        <div class="corp-dot" style="background:${corp.dot}"></div>
        <div class="corp-title">${corp.label}</div>
        <div class="corp-count" id="count-${corp.id}">${rows.length}건</div>
      </div>
      ${buildTable(rows)}
    `;
    if (rows.length === 0) sec.classList.add('section-hidden');
    main.appendChild(sec);
  });
}

function filter() {
  const vc = document.getElementById('fCorp').value;
  const vg = document.getElementById('fGrp').value;
  const ve = document.getElementById('fEmp').value;
  const kw = document.getElementById('fKw').value.toLowerCase().trim();

  let total = 0;

  document.querySelectorAll('.corp-section').forEach(sec => {
    const corpId = sec.dataset.corp;
    if (vc && corpId !== vc) { sec.classList.add('section-hidden'); return; }

    const rows = sec.querySelectorAll('tbody tr');
    let visible = 0;
    rows.forEach(tr => {
      const grpOk = !vg || tr.dataset.grp === vg;
      const empOk = !ve || tr.dataset.emp === ve;
      const kwOk = !kw || tr.dataset.nm.toLowerCase().includes(kw) || tr.dataset.req.toLowerCase().includes(kw);
      if (grpOk && empOk && kwOk) {
        tr.classList.remove('hidden');
        visible++;
      } else {
        tr.classList.add('hidden');
      }
    });

    const countEl = document.getElementById('count-' + corpId);
    if (countEl) countEl.textContent = visible + '건';
    sec.classList.toggle('section-hidden', visible === 0);
    total += visible;
  });

  document.getElementById('cnt').textContent = total + '건';
  document.getElementById('noResult').classList.toggle('hidden', total > 0);
}

// init
buildSections(DATA);
let total = DATA.length;
document.getElementById('cnt').textContent = total + '건';

['fCorp','fGrp','fEmp'].forEach(id => document.getElementById(id).addEventListener('change', filter));
document.getElementById('fKw').addEventListener('input', filter);
</script>
